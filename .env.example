# Application
APP_ENV=local
LOG_LEVEL=info

# API
API_PORT=8000

# Database
DATABASE_URL=postgresql+psycopg://belzakupki:belzakupki@localhost:5432/belzakupki
DB_HOST=db
DB_PORT=5432
DB_NAME=belzakupki
DB_USER=belzakupki
DB_PASSWORD=belzakupki

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# goszakupki.by parser
GOSZAKUPKI_VERIFY_SSL=true
GOSZAKUPKI_COOKIE=

# Telegram notifications
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id
